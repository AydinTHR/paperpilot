# ---------------------------------------------------------------------------
# PaperPilot environment configuration  --  copy to `.env` and fill in.
# `.env` is gitignored. NEVER commit real keys.
# ---------------------------------------------------------------------------

# --- Alpaca credentials (use your PAPER keys from https://app.alpaca.markets) ---
ALPACA_API_KEY=your_paper_key_id_here
ALPACA_SECRET_KEY=your_paper_secret_here

# --- Trading mode ---------------------------------------------------------
# PAPER=true  -> simulated trading against Alpaca's paper endpoint (DEFAULT, SAFE).
# PAPER=false -> real-money trading. This ALSO requires ALLOW_LIVE_TRADING=true
#                below, and will print a large warning banner on startup.
PAPER=true

# Live-trading safety gate. Must be EXACTLY "true" to permit real-money mode.
# Leaving this unset/false makes live trading impossible even if PAPER=false.
ALLOW_LIVE_TRADING=false

# --- Risk limits ----------------------------------------------------------
# Maximum fraction of account equity allowed in any single position (0.10 = 10%).
MAX_POSITION_PCT=0.10
# Daily-loss kill switch: halt + refuse new trades once today's loss exceeds
# this fraction of starting equity (0.03 = 3%).
MAX_DAILY_LOSS_PCT=0.03
# Max-drawdown halt: stop trading once equity falls this fraction below its
# all-time peak (0.20 = 20%). This halt is sticky until manually reset.
MAX_DRAWDOWN_PCT=0.20
# Per-trade stop-loss distance below entry price (0.05 = 5%). Set to 0 to disable.
STOP_LOSS_PCT=0.05

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Market data ----------------------------------------------------------
# Default bar interval for data fetches: "1d" (daily) or "1h" (hourly).
DEFAULT_INTERVAL=1d
# Where the local parquet OHLCV cache is written (gitignored).
DATA_CACHE_DIR=data/cache
# Data source: "auto" uses Alpaca when your Alpaca keys are set (same source
# as execution -> no signal/execution drift), yfinance otherwise. Set
# DATA_PROVIDER=yfinance to force the old behavior.
DATA_PROVIDER=auto
# Alpaca market data feed: "iex" (free Basic plan) or "sip" (paid).
ALPACA_DATA_FEED=iex
# Skip scheduled loop ticks while the NYSE is closed (weekends, holidays,
# half-days). --once runs are never gated.
MARKET_HOURS_ONLY=true

# --- Execution --------------------------------------------------------------
# Attach broker-held protective stops (OTO) to entries so positions stay
# protected between ticks. Unset -> enabled when Alpaca keys are present.
# USE_BROKER_STOPS=true
# Optional websocket fill listener beside the scheduled loop; reconciles fills
# that land between ticks (e.g. a stop leg firing mid-interval).
USE_TRADE_STREAM=false
# Optional: override the default trading universe (comma-separated tickers).
# UNIVERSE=AAPL,MSFT,NVDA,SPY

# --- Live loop & trade journal --------------------------------------------
# Strategy the scheduled live loop trades by default: "sma", "rsi", or "llm".
DEFAULT_STRATEGY=sma
# Minutes between scheduled loop iterations.
LOOP_INTERVAL_MINUTES=60
# SQLAlchemy URL for the trade journal. Default is a gitignored local sqlite file.
DB_URL=sqlite:///data/paperpilot.db

# --- LLM signal layer (Phase 6, optional) ---------------------------------
# Anthropic API key for the optional LLM strategy. LEAVE BLANK to disable it
# (the LLM strategy then simply HOLDs). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# LLM backend. "anthropic" is wired; other providers are reserved (drop-in).
LLM_PROVIDER=anthropic
# Model name passed to the provider (override if the alias changes).
LLM_MODEL=claude-3-5-haiku-latest
# Response cap / sampling temperature (low = consistent) / per-call timeout (s).
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=30
