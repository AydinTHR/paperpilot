# ---------------------------------------------------------------------------
# PaperPilot environment configuration  --  copy to `.env` and fill in.
# `.env` is gitignored. NEVER commit real keys.
# ---------------------------------------------------------------------------

# --- Alpaca credentials (use your PAPER keys from https://app.alpaca.markets) ---
ALPACA_API_KEY=your_paper_key_id_here
ALPACA_SECRET_KEY=your_paper_secret_here

# --- Trading mode ---------------------------------------------------------
# PAPER=true  -> simulated trading against Alpaca's paper endpoint (DEFAULT, SAFE).
# PAPER=false -> real-money trading. This ALSO requires ALLOW_LIVE_TRADING=true
#                below, and will print a large warning banner on startup.
PAPER=true

# Live-trading safety gate. Must be EXACTLY "true" to permit real-money mode.
# Leaving this unset/false makes live trading impossible even if PAPER=false.
ALLOW_LIVE_TRADING=false

# --- Risk limits ----------------------------------------------------------
# Maximum fraction of account equity allowed in any single position (0.10 = 10%).
MAX_POSITION_PCT=0.10
# Daily-loss kill switch: halt + refuse new trades once today's loss exceeds
# this fraction of starting equity (0.03 = 3%).
MAX_DAILY_LOSS_PCT=0.03

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Market data ----------------------------------------------------------
# Default bar interval for data fetches: "1d" (daily) or "1h" (hourly).
DEFAULT_INTERVAL=1d
# Where the local parquet OHLCV cache is written (gitignored).
DATA_CACHE_DIR=data/cache
# Optional: override the default trading universe (comma-separated tickers).
# UNIVERSE=AAPL,MSFT,NVDA,SPY
